# Postgres connection (Neon / Supabase / local). Local default shown.
DATABASE_URL="postgres://postgres:postgres@localhost:5432/esc_site"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="dev-only-secret-change-me-please-0123456789abcdef"

# Base URL for Auth.js callbacks
AUTH_URL="http://localhost:3000"

# Vercel Blob (mock uploads). Not required to run the demo — uploads fall back
# to a local placeholder when unset.
BLOB_READ_WRITE_TOKEN=""
